{
  "name": "jthowardesigns-react",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "start:server": "tsx server.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"vite.config.ts\" \"server.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"vite.config.ts\" \"server.ts\""
  },
  "dependencies": {
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "prettier": "^3.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^4.5.5"
  }
}
